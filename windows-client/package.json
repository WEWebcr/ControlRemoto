{
  "name": "remoto-control-jm-client",
  "version": "1.0.0",
  "description": "Cliente remoto de control desatendido para Windows - Remoto Control J&M",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "com.remotocontroljm.windowsclient",
    "productName": "Remoto Control J&M Client",
    "win": {
      "target": "nsis",
      "icon": "icon.ico",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Remoto Control J&M Client",
      "runAfterFinish": true
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "icon.png",
      "category": "public.app-category.utilities"
    },
    "asar": true,
    "asarUnpack": [
      "InputSimulator.exe"
    ],
    "files": [
      "main.js",
      "preload.js",
      "renderer.js",
      "index.html",
      "style.css",
      "InputSimulator.exe",
      "icon.png",
      "icon.ico",
      "package.json"
    ]
  },
  "dependencies": {
    "socket.io-client": "^4.7.2"
  },
  "devDependencies": {
    "electron": "^28.2.0",
    "electron-builder": "^26.8.1"
  },
  "author": "J&M",
  "license": "ISC"
}
